[
  {
    "id": "H8_CM_CTH_2_EXE",
    "name": "H8 Cloud Mask And Cloud Phase Retrieval",
    "description": "Executable H8 cloud mask and cloud phase retrieval module. The system reads H8 NetCDF input files and writes cloud product GeoTIFF results.",
    "runtime": "cpp_native",
    "entry": "CM_CTH_2.exe",
    "executable": "backend/installed_modules/H8_CM_CTH_2_EXE/CM_CTH_2.exe",
    "working_dir": "backend/installed_modules/H8_CM_CTH_2_EXE",
    "config_mode": "json_file",
    "command_template": [
      "{executable}",
      "{config_json}"
    ],
    "dependency_dirs": [
      "deps"
    ],
    "dependency_search_dirs": [],
    "resource_dirs": [
      "resources"
    ],
    "parallel": {
      "mode": "batch_group",
      "input_key": "file",
      "output_key": "outpath",
      "batch_role": "input",
      "file_patterns": "*R21*.nc;*R21*.NC",
      "output_suffix": ".tif",
      "output_naming": "source_stem",
      "output_mode": "directory",
      "files_per_job": 1,
      "chunk_multiplier": 1,
      "input_pass_mode": "directory_view",
      "batch_allow_all_files": false,
      "batch_allow_no_extension": false
    },
    "tags": [
      "h8",
      "cloud",
      "cloud-mask",
      "cloud-phase",
      "executable"
    ],
    "tool_type": "cloud",
    "enabled": true,
    "inputs": [
      {
        "key": "file",
