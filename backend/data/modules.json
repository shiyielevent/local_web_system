        "type": "dir_path",
        "required": true,
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "io_role": "input",
        "default": "D:/H8/data1/input2",
        "batch_role": "input",
        "match_mode": "each_file",
        "file_patterns": "*R21*.nc;*R21*.NC",
        "batch_allow_all_files": false,
        "batch_allow_no_extension": false,
        "batch_pass_mode": "directory_view"
      },
      {
        "key": "cm_files",
        "label": "cm_files",
        "type": "dir_path",
        "required": true,
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "io_role": "output",
        "default": "D:/H8/data1/CM",
        "batch_role": "OUTPUT_DIR",
        "output_mode": "directory"
      },
      {
        "key": "outpath",
        "label": "outpath",
        "type": "dir_path",
        "required": true,
        "visible_to_user": true,
        "admin_fixed": false,
        "path_mode": "absolute",
        "io_role": "output",
        "default": "D:/H8/data1/output",
        "batch_role": "OUTPUT_DIR",
        "output_mode": "directory"
      }
    ],
    "_manifest_format": "executable_module_json",
    "_param_json_path": "D:\\local_web_module_system\\backend\\installed_modules\\H8_CM_CTH_2_EXE\\config.json"
